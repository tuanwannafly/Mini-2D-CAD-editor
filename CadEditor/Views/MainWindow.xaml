<Window x:Class="CadEditor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CadEditor.Models"
        xmlns:converters="clr-namespace:CadEditor.Views.Converters"
        xmlns:vm="clr-namespace:CadEditor.ViewModels"
        Title="Mini CAD Editor" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="Segoe UI"
        KeyDown="Window_KeyDown">

    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveDrawingCommand}" />
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedShapeCommand}" />
    </Window.InputBindings>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <converters:Point2DToPointConverter x:Key="Point2DToPointConverter" />
        <converters:TopLeftSizeToRectConverter x:Key="TopLeftSizeToRectConverter" />
        <converters:Point2DListToPointCollectionConverter x:Key="Point2DListToPointCollectionConverter" />
        <converters:NotNullToVisibilityConverter x:Key="NotNullToVisibilityConverter" />

        <!-- Shape stroke style with elegant selection cue -->
        <Style x:Key="ShapeStrokeStyle" TargetType="Shape">
            <Setter Property="Stroke" Value="{Binding StrokeColor}" />
            <Setter Property="StrokeThickness" Value="{Binding StrokeThickness}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Stroke" Value="#2563EB" />
                    <Setter Property="StrokeThickness" Value="4" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ============ TYPOGRAPHY ============ -->
        <Style x:Key="Heading" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#1F1F1F" />
        </Style>

        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#6B7280" />
        </Style>

        <Style x:Key="Code" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12.5" />
        </Style>

        <!-- ============ MONOGRAM BADGE (replaces icons) ============ -->
        <Style x:Key="MonogramBorder" TargetType="Border">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="MonogramText" TargetType="TextBlock" BasedOn="{StaticResource Heading}">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#1F1F1F" />
        </Style>

        <!-- ============ TOOL BUTTON (chữ cái monogram đầu) ============ -->
        <Style x:Key="ToolButtonStyle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E5E7EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E5E7EB" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F1F1F" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1F1F1F" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F9FAFB" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#D1D5DB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#D1D5DB" />
                                <Setter TargetName="Bd" Property="Background" Value="#FAFAFA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary action button (Save) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource MiniButtonStyle}">
            <Setter Property="Background" Value="#1F1F1F" />
            <Setter Property="BorderBrush" Value="#1F1F1F" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#374151" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#374151" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#000000" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#9CA3AF" />
                                <Setter TargetName="Bd" Property="Background" Value="#E5E7EB" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E5E7EB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle pill (Snap) -->
        <Style x:Key="TogglePillStyle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F9FAFB" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FF" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#BFDBFE" />
                                <Setter Property="Foreground" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Cleaner TextBox -->
        <Style x:Key="CleanTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#1F1F1F" />
            <Setter Property="CaretBrush" Value="#2563EB" />
            <Setter Property="SelectionBrush" Value="#BFDBFE" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#D1D5DB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CleanComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Foreground" Value="#1F1F1F" />
        </Style>

        <!-- Tiny vertical divider -->
        <Style x:Key="VDivider" TargetType="Rectangle">
            <Setter Property="Width" Value="1" />
            <Setter Property="Fill" Value="#E5E7EB" />
            <Setter Property="Margin" Value="12,4" />
        </Style>

        <!-- ============ SHAPE TEMPLATES ============ -->
        <DataTemplate DataType="{x:Type models:LineShape}">
            <Line X1="{Binding Start.X}" Y1="{Binding Start.Y}"
                  X2="{Binding End.X}" Y2="{Binding End.Y}"
                  StrokeThickness="{Binding StrokeThickness}"
                  RenderTransform="{Binding RenderTransform}"
                  Style="{StaticResource ShapeStrokeStyle}" />
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:CircleShape}">
            <Path Style="{StaticResource ShapeStrokeStyle}" Fill="Transparent"
                  RenderTransform="{Binding RenderTransform}">
                <Path.Data>
                    <EllipseGeometry Center="{Binding Center, Converter={StaticResource Point2DToPointConverter}}"
                                      RadiusX="{Binding Radius}" RadiusY="{Binding Radius}" />
                </Path.Data>
            </Path>
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:RectangleShape}">
            <Path Style="{StaticResource ShapeStrokeStyle}" Fill="Transparent"
                  RenderTransform="{Binding RenderTransform}">
                <Path.Data>
                    <RectangleGeometry>
                        <RectangleGeometry.Rect>
                            <MultiBinding Converter="{StaticResource TopLeftSizeToRectConverter}">
                                <Binding Path="TopLeft" />
                                <Binding Path="Width" />
                                <Binding Path="Height" />
                            </MultiBinding>
                        </RectangleGeometry.Rect>
                    </RectangleGeometry>
                </Path.Data>
            </Path>
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:PolygonShape}">
            <Polygon Points="{Binding Vertices, Converter={StaticResource Point2DListToPointCollectionConverter}}"
                     StrokeThickness="{Binding StrokeThickness}"
                     Fill="Transparent"
                     RenderTransform="{Binding RenderTransform}"
                     Style="{StaticResource ShapeStrokeStyle}" />
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:ArcShape}">
            <Path Style="{StaticResource ShapeStrokeStyle}" StrokeDashArray="4 2" Fill="Transparent"
                  RenderTransform="{Binding RenderTransform}">
                <Path.Data>
                    <EllipseGeometry Center="{Binding Center, Converter={StaticResource Point2DToPointConverter}}"
                                      RadiusX="{Binding Radius}" RadiusY="{Binding Radius}" />
                </Path.Data>
            </Path>
        </DataTemplate>
    </Window.Resources>

    <!-- ============ LAYOUT ============ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="200" />
        </Grid.RowDefinitions>

        <!-- ============ TOOLBAR ============ -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="14,10">
            <StackPanel Orientation="Vertical">
                <!-- Row 1: brand + tools -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="26" Height="26" CornerRadius="7" Background="#1F1F1F" Margin="0,0,10,0">
                            <TextBlock Text="M" Foreground="White" FontSize="13" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Mini CAD Editor" Style="{StaticResource Heading}" FontSize="14" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <!-- Tools: monogram + label (no icons) -->
                        <ToggleButton x:Name="ToolSelect" Style="{StaticResource ToolButtonStyle}"
                                      ToolTip="Select tool  (Esc)"
                                      IsChecked="{Binding IsSelectToolActive}">
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource MonogramBorder}">
                                    <TextBlock Style="{StaticResource MonogramText}" Text="S" />
                                </Border>
                                <TextBlock Text="Select" VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                        <Rectangle Style="{StaticResource VDivider}" />
                        <ToggleButton x:Name="ToolLine" Style="{StaticResource ToolButtonStyle}"
                                      ToolTip="Line tool"
                                      IsChecked="{Binding IsLineToolActive}">
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource MonogramBorder}">
                                    <TextBlock Style="{StaticResource MonogramText}" Text="L" />
                                </Border>
                                <TextBlock Text="Line" VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                        <Rectangle Style="{StaticResource VDivider}" />
                        <ToggleButton x:Name="ToolCircle" Style="{StaticResource ToolButtonStyle}"
                                      ToolTip="Circle tool"
                                      IsChecked="{Binding IsCircleToolActive}">
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource MonogramBorder}">
                                    <TextBlock Style="{StaticResource MonogramText}" Text="O" />
                                </Border>
                                <TextBlock Text="Circle" VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                        <Rectangle Style="{StaticResource VDivider}" />
                        <ToggleButton x:Name="ToolRect" Style="{StaticResource ToolButtonStyle}"
                                      ToolTip="Rectangle tool"
                                      IsChecked="{Binding IsRectToolActive}">
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource MonogramBorder}">
                                    <TextBlock Style="{StaticResource MonogramText}" Text="R" />
                                </Border>
                                <TextBlock Text="Rect" VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                        <Rectangle Style="{StaticResource VDivider}" />
                        <ToggleButton x:Name="ToolPolygon" Style="{StaticResource ToolButtonStyle}"
                                      ToolTip="Polygon tool"
                                      IsChecked="{Binding IsPolygonToolActive}">
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource MonogramBorder}">
                                    <TextBlock Style="{StaticResource MonogramText}" Text="P" />
                                </Border>
                                <TextBlock Text="Polygon" VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                        <Rectangle Style="{StaticResource VDivider}" />
                        <ToggleButton x:Name="ToolMove" Style="{StaticResource ToolButtonStyle}"
                                      ToolTip="Move selected shape"
                                      IsChecked="{Binding IsMoveToolActive}">
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource MonogramBorder}">
                                    <TextBlock Style="{StaticResource MonogramText}" Text="M" />
                                </Border>
                                <TextBlock Text="Move" VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                    </StackPanel>
                </Grid>

                <!-- Row 2: history + snap + persistence -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- History -->
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource MiniButtonStyle}"
                                Command="{Binding UndoCommand}"
                                IsEnabled="{Binding CanUndo}"
                                ToolTip="Undo (Ctrl+Z)">
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource MonogramBorder}" Width="20" Height="20" Margin="0,0,6,0">
                                    <TextBlock Style="{StaticResource MonogramText}" Text="Z" FontSize="10" />
                                </Border>
                                <TextBlock Text="Undo" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MiniButtonStyle}"
                                Command="{Binding RedoCommand}"
                                IsEnabled="{Binding CanRedo}"
                                Margin="6,0,0,0"
                                ToolTip="Redo (Ctrl+Y)">
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource MonogramBorder}" Width="20" Height="20" Margin="0,0,6,0">
                                    <TextBlock Style="{StaticResource MonogramText}" Text="Y" FontSize="10" />
                                </Border>
                                <TextBlock Text="Redo" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Snap toggles -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0">
                        <ToggleButton Style="{StaticResource TogglePillStyle}"
                                      IsChecked="{Binding SnapToGridEnabled}"
                                      ToolTip="Snap drawing to grid">
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource MonogramBorder}" Width="20" Height="20" Margin="0,0,6,0">
                                    <TextBlock Style="{StaticResource MonogramText}" Text="#" FontSize="11" />
                                </Border>
                                <TextBlock Text="Snap Grid" VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource TogglePillStyle}" Margin="6,0,0,0"
                                      IsChecked="{Binding SnapToPointEnabled}"
                                      ToolTip="Snap drawing to endpoints">
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource MonogramBorder}" Width="20" Height="20" Margin="0,0,6,0">
                                    <TextBlock Style="{StaticResource MonogramText}" Text="·" FontSize="14" />
                                </Border>
                                <TextBlock Text="Snap Point" VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                        <Border Background="#F3F4F6" CornerRadius="6" Padding="10,6" Margin="10,0,0,0" BorderBrush="#E5E7EB" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Grid" Style="{StaticResource Muted}" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding GridSize, StringFormat='{}{0:0}'}" Style="{StaticResource Heading}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Persistence -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                        <Border Background="#F3F4F6" CornerRadius="6" Padding="10,6" Margin="0,0,6,0" BorderBrush="#E5E7EB" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Format" Style="{StaticResource Muted}" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <ComboBox Style="{StaticResource CleanComboBoxStyle}" Width="80"
                                          ItemsSource="{Binding PersistenceFormats}"
                                          SelectedItem="{Binding SelectedPersistenceFormat}" />
                            </StackPanel>
                        </Border>
                        <TextBox Style="{StaticResource CleanTextBoxStyle}" Width="180"
                                 Text="{Binding PersistencePath, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="File name (saved in working directory)" />
                        <Button Style="{StaticResource PrimaryButtonStyle}" Margin="6,0,0,0"
                                Command="{Binding SaveDrawingCommand}" ToolTip="Save drawing (Ctrl+S)">
                            <TextBlock Text="Save" />
                        </Button>
                        <Button Style="{StaticResource MiniButtonStyle}" Margin="6,0,0,0"
                                Command="{Binding LoadDrawingCommand}">
                            <TextBlock Text="Load" />
                        </Button>
                        <Border Background="#F9FAFB" CornerRadius="6" Padding="10,6" Margin="10,0,0,0" BorderBrush="#E5E7EB" BorderThickness="1">
                            <TextBlock Text="{Binding PersistenceStatus}" Style="{StaticResource Muted}" VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ============ CANVAS AREA ============ -->
        <Grid Grid.Row="1" Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Drawing canvas with subtle dotted grid background -->
            <Grid ClipToBounds="True" Background="White">
                <!-- Soft grid pattern drawn behind canvas -->
                <Canvas x:Name="GridOverlay" IsHitTestVisible="False" />
                <Canvas x:Name="DrawingCanvas" Background="Transparent" ClipToBounds="True"
                        MouseLeftButtonDown="DrawingCanvas_MouseLeftButtonDown"
                        MouseMove="DrawingCanvas_MouseMove"
                        MouseLeftButtonUp="DrawingCanvas_MouseLeftButtonUp" />

                <ItemsControl ItemsSource="{Binding Shapes}" IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Background="Transparent" ClipToBounds="True" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <ContentControl Content="{Binding PreviewShape}" IsHitTestVisible="False" />

                <Canvas IsHitTestVisible="False">
                    <Line X1="{Binding RotationLineX1}" Y1="{Binding RotationLineY1}"
                          X2="{Binding RotationLineX2}" Y2="{Binding RotationLineY2}"
                          Stroke="#10B981" StrokeThickness="1.4" StrokeDashArray="3 3"
                          Visibility="{Binding SelectedShape, Converter={StaticResource NotNullToVisibilityConverter}}" />
                </Canvas>

                <ItemsControl ItemsSource="{Binding TransformHandles}" IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:TransformHandleInfo}">
                            <Ellipse Width="12" Height="12" Fill="White" Stroke="#2563EB"
                                     StrokeThickness="1.5">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Type}" Value="Rotation">
                                                <Setter Property="Fill" Value="#10B981" />
                                                <Setter Property="Stroke" Value="#10B981" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- Inline status strip inside canvas row -->
            <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="14,8">
                <StackPanel Orientation="Horizontal">
                    <Border Background="White" CornerRadius="6" Padding="10,5" Margin="0,0,8,0" BorderBrush="#E5E7EB" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Cursor" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding MousePositionStatus}" Style="{StaticResource Code}" Foreground="#1F1F1F" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="6" Padding="10,5" Margin="0,0,8,0" BorderBrush="#E5E7EB" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Selection" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding SelectedShapeStatus}" Style="{StaticResource Code}" Foreground="#1F1F1F" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="6" Padding="10,5" BorderBrush="#E5E7EB" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Tool" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding CurrentTool}" Style="{StaticResource Code}" Foreground="#1F1F1F" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ============ CLI PANEL ============ -->
        <Border Grid.Row="3" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="14,10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#1F1F1F" Width="22" Height="22" CornerRadius="5" Margin="0,0,10,0">
                            <TextBlock Text="&gt;_" FontSize="10" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Console" Style="{StaticResource Heading}" VerticalAlignment="Center" />
                        <TextBlock Text=" · Enter to run" Style="{StaticResource Muted}" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="White" Padding="14,10">
                    <ItemsControl ItemsSource="{Binding CliLog}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Style="{StaticResource Code}"
                                           Foreground="#1F1F1F" Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="2" Background="#FAFAFA" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&gt;" Style="{StaticResource Code}" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" FontWeight="SemiBold" />
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource CleanTextBoxStyle}"
                                 Text="{Binding CliInput, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Type a command and press Enter">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SubmitCliInputCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
