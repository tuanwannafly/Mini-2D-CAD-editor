<Window x:Class="CadEditor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:CadEditor.Models"
        xmlns:converters="clr-namespace:CadEditor.Views.Converters"
        xmlns:vm="clr-namespace:CadEditor.ViewModels"
        Title="Mini CAD Editor" Height="720" Width="1280"
        KeyDown="Window_KeyDown">

    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveDrawingCommand}" />
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedShapeCommand}" />
    </Window.InputBindings>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <converters:Point2DToPointConverter x:Key="Point2DToPointConverter" />
        <converters:TopLeftSizeToRectConverter x:Key="TopLeftSizeToRectConverter" />
        <converters:Point2DListToPointCollectionConverter x:Key="Point2DListToPointCollectionConverter" />
        <converters:NotNullToVisibilityConverter x:Key="NotNullToVisibilityConverter" />

        <Style x:Key="ShapeStrokeStyle" TargetType="Shape">
            <Setter Property="Stroke" Value="{Binding StrokeColor}" />
            <Setter Property="StrokeThickness" Value="{Binding StrokeThickness}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Stroke" Value="#FF8C00" />
                    <Setter Property="StrokeThickness" Value="4" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="1,0" />
            <Setter Property="MinWidth" Value="72" />
        </Style>

        <Style x:Key="ToolIconStyle" TargetType="Path">
            <Setter Property="Stroke" Value="#333333" />
            <Setter Property="StrokeThickness" Value="1.8" />
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Margin" Value="0,0,5,0" />
        </Style>

        <DataTemplate DataType="{x:Type models:LineShape}">
            <Line X1="{Binding Start.X}" Y1="{Binding Start.Y}"
                  X2="{Binding End.X}" Y2="{Binding End.Y}"
                  StrokeThickness="{Binding StrokeThickness}"
                  Style="{StaticResource ShapeStrokeStyle}" />
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:CircleShape}">
            <Path Style="{StaticResource ShapeStrokeStyle}" Fill="Transparent"
                  RenderTransform="{Binding RenderTransform}" RenderTransformOrigin="0.5,0.5">
                <Path.Data>
                    <EllipseGeometry Center="{Binding Center, Converter={StaticResource Point2DToPointConverter}}"
                                      RadiusX="{Binding Radius}" RadiusY="{Binding Radius}" />
                </Path.Data>
            </Path>
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:RectangleShape}">
            <Path Style="{StaticResource ShapeStrokeStyle}" Fill="Transparent">
                <Path.Data>
                    <RectangleGeometry>
                        <RectangleGeometry.Rect>
                            <MultiBinding Converter="{StaticResource TopLeftSizeToRectConverter}">
                                <Binding Path="TopLeft" />
                                <Binding Path="Width" />
                                <Binding Path="Height" />
                            </MultiBinding>
                        </RectangleGeometry.Rect>
                    </RectangleGeometry>
                </Path.Data>
            </Path>
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:PolygonShape}">
            <Polygon Points="{Binding Vertices, Converter={StaticResource Point2DListToPointCollectionConverter}}"
                     StrokeThickness="{Binding StrokeThickness}"
                     Fill="Transparent"
                     Style="{StaticResource ShapeStrokeStyle}" />
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:ArcShape}">
            <Path Style="{StaticResource ShapeStrokeStyle}" StrokeDashArray="4 2" Fill="Transparent">
                <Path.Data>
                    <EllipseGeometry Center="{Binding Center, Converter={StaticResource Point2DToPointConverter}}"
                                      RadiusX="{Binding Radius}" RadiusY="{Binding Radius}" />
                </Path.Data>
            </Path>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="170" />
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0">
            <Button Style="{StaticResource ToolButtonStyle}" Command="{Binding SelectToolCommand}"
                    CommandParameter="{x:Static vm:DrawingTool.Select}" ToolTip="Select (Esc cancels drawing)">
                <StackPanel Orientation="Horizontal">
                    <Path Style="{StaticResource ToolIconStyle}" Fill="#333333" Data="M2,1 L16,9 L9,10 L6,17 Z" />
                    <TextBlock Text="Select" />
                </StackPanel>
            </Button>
            <Separator />
            <Button Style="{StaticResource ToolButtonStyle}" Command="{Binding SelectToolCommand}"
                    CommandParameter="{x:Static vm:DrawingTool.Line}" ToolTip="Line tool">
                <StackPanel Orientation="Horizontal">
                    <Path Style="{StaticResource ToolIconStyle}" Data="M2,16 L16,2" />
                    <TextBlock Text="Line" />
                </StackPanel>
            </Button>
            <Button Style="{StaticResource ToolButtonStyle}" Command="{Binding SelectToolCommand}"
                    CommandParameter="{x:Static vm:DrawingTool.Circle}" ToolTip="Circle tool">
                <StackPanel Orientation="Horizontal">
                    <Path Style="{StaticResource ToolIconStyle}" Data="M9,1 A8,8 0 1 1 8.9,1" />
                    <TextBlock Text="Circle" />
                </StackPanel>
            </Button>
            <Button Style="{StaticResource ToolButtonStyle}" Command="{Binding SelectToolCommand}"
                    CommandParameter="{x:Static vm:DrawingTool.Rectangle}" ToolTip="Rectangle tool">
                <StackPanel Orientation="Horizontal">
                    <Path Style="{StaticResource ToolIconStyle}" Data="M2,3 H16 V15 H2 Z" />
                    <TextBlock Text="Rect" />
                </StackPanel>
            </Button>
            <Button Style="{StaticResource ToolButtonStyle}" Command="{Binding SelectToolCommand}"
                    CommandParameter="{x:Static vm:DrawingTool.Polygon}" ToolTip="Polygon tool">
                <StackPanel Orientation="Horizontal">
                    <Path Style="{StaticResource ToolIconStyle}" Data="M9,1 L17,7 L14,17 H4 L1,7 Z" />
                    <TextBlock Text="Polygon" />
                </StackPanel>
            </Button>
            <Button Style="{StaticResource ToolButtonStyle}" Command="{Binding SelectToolCommand}"
                    CommandParameter="{x:Static vm:DrawingTool.None}" ToolTip="Move selected shape">
                <StackPanel Orientation="Horizontal">
                    <Path Style="{StaticResource ToolIconStyle}" Data="M9,1 V17 M1,9 H17 M9,1 L6,4 M9,1 L12,4 M9,17 L6,14 M9,17 L12,14 M1,9 L4,6 M1,9 L4,12 M17,9 L14,6 M17,9 L14,12" />
                    <TextBlock Text="Move" />
                </StackPanel>
            </Button>
            <Separator />
            <Button Content="Undo (Ctrl+Z)" Command="{Binding UndoCommand}" IsEnabled="{Binding CanUndo}" />
            <Button Content="Redo (Ctrl+Y)" Command="{Binding RedoCommand}" IsEnabled="{Binding CanRedo}" />
            <Separator />
            <ToggleButton Content="Snap Grid" IsChecked="{Binding SnapToGridEnabled}" />
            <ToggleButton Content="Snap Point" IsChecked="{Binding SnapToPointEnabled}" />
            <TextBlock Text="{Binding GridSize, StringFormat='Grid: {0:0}'}" VerticalAlignment="Center" Margin="4,0" />
            <Separator />
            <TextBlock Text="Save as" VerticalAlignment="Center" Margin="4,0" />
            <ComboBox ItemsSource="{Binding PersistenceFormats}"
                      SelectedItem="{Binding SelectedPersistenceFormat}"
                      Width="80" />
            <TextBox Text="{Binding PersistencePath, UpdateSourceTrigger=PropertyChanged}"
                     Width="160" Margin="4,0" />
            <Button Content="Save" Command="{Binding SaveDrawingCommand}" />
            <Button Content="Load" Command="{Binding LoadDrawingCommand}" />
            <TextBlock Text="{Binding PersistenceStatus}" VerticalAlignment="Center" Margin="8,0" />
            <Separator />
            <TextBlock Text="{Binding CurrentTool, StringFormat='Tool: {0}'}" VerticalAlignment="Center" Margin="8,0" />
        </ToolBar>

        <Grid Grid.Row="1">
            <Canvas x:Name="DrawingCanvas" Background="White" ClipToBounds="True"
                    MouseLeftButtonDown="DrawingCanvas_MouseLeftButtonDown"
                    MouseMove="DrawingCanvas_MouseMove"
                    MouseLeftButtonUp="DrawingCanvas_MouseLeftButtonUp" />

            <ItemsControl ItemsSource="{Binding Shapes}" IsHitTestVisible="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Background="Transparent" ClipToBounds="True" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <ContentControl Content="{Binding PreviewShape}" IsHitTestVisible="False" />

            <Canvas IsHitTestVisible="False">
                <Line X1="{Binding RotationLineX1}" Y1="{Binding RotationLineY1}"
                      X2="{Binding RotationLineX2}" Y2="{Binding RotationLineY2}"
                      Stroke="Green" StrokeThickness="1" StrokeDashArray="3 2"
                      Visibility="{Binding SelectedShape, Converter={StaticResource NotNullToVisibilityConverter}}" />
            </Canvas>

            <ItemsControl ItemsSource="{Binding TransformHandles}" IsHitTestVisible="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                        <Setter Property="Canvas.Top" Value="{Binding Y}" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:TransformHandleInfo}">
                        <Ellipse Width="10" Height="10" Fill="White" Stroke="Blue"
                                 StrokeThickness="1.5">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="Rotation">
                                            <Setter Property="Fill" Value="Transparent" />
                                            <Setter Property="Stroke" Value="Green" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <StatusBar Grid.Row="2" Background="#F3F3F3" BorderBrush="#D0D0D0" BorderThickness="0,1,0,1">
            <StatusBarItem>
                <TextBlock Text="{Binding MousePositionStatus}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding SelectedShapeStatus}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="Shortcuts: Ctrl+S Save, Ctrl+Z Undo, Ctrl+Y Redo, Delete Remove" />
            </StatusBarItem>
        </StatusBar>

        <Border Grid.Row="3" Background="#1E1E1E" BorderBrush="#3A3A3A" BorderThickness="1,1,0,0" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding CliLog}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#DCDCDC" FontFamily="Consolas" FontSize="13" Margin="0,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBox Grid.Row="1" Text="{Binding CliInput, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Consolas" FontSize="14" Margin="0,8,0,0" Padding="6"
                         Background="#252526" Foreground="#FFFFFF" BorderBrush="#555555"
                         CaretBrush="#FFFFFF">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SubmitCliInputCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
            </Grid>
        </Border>
    </Grid>
</Window>
